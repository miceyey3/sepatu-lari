<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sepatu Lari Kalcer</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      background: #f5f5f5;
    }

    /* NAVBAR */
    nav {
      background: #111;
      color: white;
      display: flex;
      justify-content: space-between;
      padding: 15px 20px;
      position: sticky;
      top: 0;
    }

    nav .logo {
      font-weight: bold;
      font-size: 18px;
    }

    nav ul {
      display: flex;
      list-style: none;
    }

    nav ul li {
      margin-left: 15px;
    }

    nav ul li a {
      color: white;
      text-decoration: none;
    }

    /* HERO */
    .hero {
      text-align: center;
      padding: 60px 20px;
      background: #222;
      color: white;
    }

    /* PRODUK */
    .container {
      padding: 20px;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
    }

    .card {
      background: white;
      padding: 15px;
      border-radius: 10px;
      text-align: center;
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }

    .card img {
      width: 100%;
      border-radius: 10px;
    }

    .price {
      font-weight: bold;
      margin: 10px 0;
    }

    .btn {
      display: inline-block;
      padding: 10px;
      background: black;
      color: white;
      text-decoration: none;
      border-radius: 5px;
    }

    .btn:hover {
      background: #444;
    }

    /* KONTAK */
    .contact {
      background: #111;
      color: white;
      padding: 40px 20px;
      text-align: center;
    }

    .contact p {
      margin: 5px 0;
    }

    /* RESPONSIVE */
    @media (max-width: 600px) {
      nav {
        flex-direction: column;
        align-items: center;
      }

      nav ul {
        flex-direction: column;
        margin-top: 10px;
      }

      nav ul li {
        margin: 5px 0;
      }
    }
  </style>
</head>

<body>

  <!-- NAVBAR -->
  <nav>
    <div class="logo">Kalcer Shoes</div>
    <ul>
      <li><a href="#">Home</a></li>
      <li><a href="#produk">Produk</a></li>
      <li><a href="#kontak">Kontak</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <h1>Sepatu Lari Kalcer</h1>
    <p>Sepatu lari modern, ringan, dan stylish</p>
  </section>

  <!-- PRODUK -->
  <section id="produk" class="container">

    <div class="card">
      <img src="https://via.placeholder.com/300" alt="Sepatu 1">
      <h3>Running Pro X</h3>
      <p class="price">Rp 350.000</p>
      <a href="#" class="btn">Tambah ke Keranjang</a>
    </div>

    <div class="card">
      <img src="https://via.placeholder.com/300" alt="Sepatu 2">
      <h3>Speed Runner</h3>
      <p class="price">Rp 420.000</p>
      <a href="#" class="btn">Tambah ke Keranjang</a>
    </div>

    <div class="card">
      <img src="https://via.placeholder.com/300" alt="Sepatu 3">
      <h3>Ultra Boost Lite</h3>
      <p class="price">Rp 500.000</p>
      <a href="#" class="btn">Tambah ke Keranjang</a>
    </div>

  </section>

  <!-- KONTAK -->
  <section id="kontak" class="contact">
    <h2>Kontak Penjual</h2>
    <p>📱 WhatsApp: 0812-3456-7890</p>
    <p>📧 Email: kalcershoes@gmail.com</p>
    <p>📍 Lokasi: Indonesia</p>
  </section>

</body>
</html>
